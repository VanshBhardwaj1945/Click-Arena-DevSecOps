pipeline {
    agent any
    
    environment {
        ACR_NAME   = 'clickarenaregistry'
        ACR_LOGIN  = "${ACR_NAME}.azurecr.io"
        IMAGE_NAME = 'click-arena'
        RG         = 'click-arena-rg'
        APP_NAME   = 'click-arena'
        IMAGE_TAG  = "v${BUILD_NUMBER}"
    }
    
    stages {

        stage('Checkout') {
            steps {
                echo '--- Retrieving GitHub Code ---'
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '--- Building Docker Image ---'
                sh 'docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Push to ACR') {
            steps {
                echo '--- Pushing to Azure Container Registry ---'
                withCredentials([
                    string(credentialsId: 'ACR_PASSWORD', variable: 'PASS'),
                    string(credentialsId: 'ACR_USERNAME', variable: 'USER')
                ]) {
                    sh '''
                        echo $PASS | docker login ${ACR_LOGIN} --username $USER --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${ACR_LOGIN}/${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${ACR_LOGIN}/${IMAGE_NAME}:${IMAGE_TAG}
                    '''
                }
            }
        }

        stage('Deploy to Container App') {
            steps {
                echo '--- Deploying to Azure Container App ---'
                withCredentials([
                    string(credentialsId: 'AZURE_CREDENTIALS', variable: 'AZ_CREDS')
                ]) {
                    sh '''
                        CLIENT_ID=$(echo $AZ_CREDS | python3 -c "import sys,json; print(json.load(sys.stdin)['clientId'])")
                        CLIENT_SECRET=$(echo $AZ_CREDS | python3 -c "import sys,json; print(json.load(sys.stdin)['clientSecret'])")
                        TENANT_ID=$(echo $AZ_CREDS | python3 -c "import sys,json; print(json.load(sys.stdin)['tenantId'])")

                        docker run --rm \
                            -e AZURE_CLIENT_ID=$CLIENT_ID \
                            -e AZURE_CLIENT_SECRET=$CLIENT_SECRET \
                            -e AZURE_TENANT_ID=$TENANT_ID \
                            mcr.microsoft.com/azure-cli \
                            bash -c "
                                az login --service-principal \
                                    --username \$AZURE_CLIENT_ID \
                                    --password \$AZURE_CLIENT_SECRET \
                                    --tenant \$AZURE_TENANT_ID &&
                                az containerapp update \
                                    --name click-arena \
                                    --resource-group click-arena-rg \
                                    --image clickarenaregistry.azurecr.io/click-arena:v3
                            "
                    '''
                }
            }
        }

        stage('Smoke Test') {
            steps {
                echo '--- Confirming app is alive ---'
                sh '''
                    sleep 15
                    curl -f https://click-arena.mangobush-de01fc2e.eastus.azurecontainerapps.io/health
                '''
            }
        }

    }

    post {
        success { echo 'Pipeline COMPLETE — game is live' }
        failure { echo 'Pipeline FAILED — check logs above' }
        always  { sh 'docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true' }
    }
}